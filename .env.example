# Supabase Credentials
# Get these from your Supabase Project Settings -> API
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_KEY="your-service-role-key-or-anon-key"

# Backend runtime tuning (recommended defaults for single-instance hosting)
UPLOAD_DIR="/tmp/classroom_uploads"
CLEANUP_UPLOADS="true"
DETECT_INTERVAL="1"
RECHECK_INTERVAL="1.5"
BEHAVIOR_INTERVAL="1.0"
PROCESSING_WIDTH="960"
REQUIRE_SINGLE_WORKER="true"
MAX_STREAM_SECONDS="0"
RECOGNITION_THRESHOLD="0.1"
RECOGNITION_MIN_MARGIN="0.01"
